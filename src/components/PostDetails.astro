---
import dayjs from "dayjs"

interface Props {
  datePublished: Date | string
  timeToRead: number
}

const { datePublished, timeToRead } = Astro.props
const formattedDate = dayjs(datePublished).format("DD MMMM YYYY")
---

<span class="post-details">
  <span class="date">{formattedDate}</span>
  <svg
    class="eyeglasses-icon"
    aria-hidden="true"
    viewBox="0 0 61.625 61.625"
    xmlns="http://www.w3.org/2000/svg"
    width="1em"
    height="1em"
    stroke="currentColor"
    fill="currentColor"
    ><g
      ><path
        d="M1,29.957h1.787c-0.009,0.201-0.03,0.398-0.03,0.602c0,6.979,5.679,12.66,12.66,12.66s12.66-5.681,12.66-12.66 c0-0.203-0.021-0.4-0.03-0.602h5.785c-0.031,0.367-0.056,0.736-0.056,1.111c0,6.98,5.679,12.66,12.659,12.66 c6.981,0,12.66-5.68,12.66-12.66c0-0.375-0.023-0.744-0.056-1.111h1.585c0.553,0,1-0.447,1-1c0-0.553-0.447-1-1-1h-1.932 c-1.393-5.479-6.352-9.549-12.258-9.549c-5.904,0-10.865,4.07-12.256,9.549h-6.374c-1.203-5.736-6.299-10.059-12.389-10.059 c-6.09,0-11.186,4.322-12.389,10.059H1c-0.552,0-1,0.447-1,1S0.448,29.957,1,29.957z M46.436,20.409 c5.879,0,10.66,4.781,10.66,10.66c0,5.878-4.781,10.66-10.66,10.66c-5.877,0-10.659-4.782-10.659-10.66 C35.776,25.189,40.559,20.409,46.436,20.409z M15.417,19.898c5.878,0,10.66,4.781,10.66,10.66c0,5.877-4.782,10.66-10.66,10.66 s-10.66-4.783-10.66-10.66C4.757,24.68,9.539,19.898,15.417,19.898z"
      ></path></g
    ></svg>{timeToRead} min read
</span>

<style>
  .post-details {
    font-size: 0.7rem;
  }

  .date {
    margin-right: 15px;
  }

  .eyeglasses-icon {
    position: relative;
    top: 0.3rem;
    font-size: 1.1rem;
    margin-right: 5px;
  }
</style>
