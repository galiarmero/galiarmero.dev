---
interface Props {
  isPrevious?: boolean
  slug: string
  title: string
}

const { isPrevious = false, slug, title } = Astro.props
const alignment = isPrevious ? "left" : "right"
---

<aside class="suggested-post" style={`text-align: ${alignment};`}>
  <span>
    <a
      href={slug}
      class="arrow-link clickable-icon"
      aria-label={isPrevious ? "Previous post" : "Next post"}
    >
      {
        isPrevious ? (
          <svg
            stroke="currentColor"
            fill="currentColor"
            stroke-width="0"
            viewBox="0 0 448 512"
            height="1em"
            width="1em"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M257.5 445.1l-22.2 22.2c-9.4 9.4-24.6 9.4-33.9 0L7 273c-9.4-9.4-9.4-24.6 0-33.9L201.4 44.7c9.4-9.4 24.6-9.4 33.9 0l22.2 22.2c9.5 9.5 9.3 25-.4 34.3L136.6 216H424c13.3 0 24 10.7 24 24v32c0 13.3-10.7 24-24 24H136.6l120.5 114.8c9.8 9.3 10 24.8.4 34.3z" />
          </svg>
        ) : (
          <svg
            stroke="currentColor"
            fill="currentColor"
            stroke-width="0"
            viewBox="0 0 448 512"
            height="1em"
            width="1em"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z" />
          </svg>
        )
      }
    </a>
  </span>
  <h2 class="suggested-title">
    <a href={slug}>{title}</a>
  </h2>
</aside>

<style>
  .suggested-post {
    display: flex;
    flex-direction: column;
    margin: 20px 0;
  }

  .arrow-link {
    color: var(--accentColor);
    cursor: pointer;
    font-size: 1.2rem;
    text-decoration: none;
  }

  .arrow-link::after {
    content: none;
  }

  .arrow-link:hover {
    opacity: 0.8;
  }

  .suggested-title {
    font-size: 1.1rem;
    letter-spacing: 0.08rem;
    margin: 0;
  }

  .suggested-title a {
    color: var(--headingColor);
    text-decoration: none;
  }

  .suggested-title a::after {
    content: none;
  }

  .suggested-title a:hover {
    color: var(--accentColor);
  }

  .suggested-title a:hover::after {
    content: none;
  }
</style>
