---
import { formatDateEu, formatDateEuNoYear, getRelativeDayName } from "../utils"

interface Props {
  date: string
  prevDate: string | null
  nextDate: string | null
  prevSlug: string | null
  nextSlug: string | null
}

const { date, prevDate, nextDate, prevSlug, nextSlug } = Astro.props
---

<div class="puzzle-scores-nav">
  <div class="intro">Puzzle scores for</div>
  <nav>
    <div>
      {prevSlug && (
        <a href={prevSlug} class="nav-chevron" aria-label="Previous day">
          <svg aria-hidden="true" viewBox="0 0 320 512" width="36" height="36" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M34.52 239.03L228.87 44.69c9.37-9.37 24.57-9.37 33.94 0l22.67 22.67c9.36 9.36 9.37 24.52.04 33.9L131.49 256l154.02 154.75c9.34 9.38 9.32 24.54-.04 33.9l-22.67 22.67c-9.37 9.37-24.57 9.37-33.94 0L34.52 272.97c-9.37-9.37-9.37-24.57 0-33.94z"/>
          </svg>
        </a>
      )}
    </div>
    <div>
      <h1 class="puzzle-nav-heading">{getRelativeDayName(date)}</h1>
    </div>
    <div>
      {nextSlug && (
        <a href={nextSlug} class="nav-chevron" aria-label="Next day">
          <svg aria-hidden="true" viewBox="0 0 320 512" width="36" height="36" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"/>
          </svg>
        </a>
      )}
    </div>
    <div class="date-label date-nav">
      {prevSlug && (
        <a href={prevSlug} class="text-link">{formatDateEuNoYear(prevDate)}</a>
      )}
    </div>
    <div class="date-label">{formatDateEu(date)}</div>
    <div class="date-label date-nav">
      {nextSlug && (
        <a href={nextSlug} class="text-link">{formatDateEuNoYear(nextDate)}</a>
      )}
    </div>
  </nav>
</div>

<style>
  .nav-chevron {
    color: var(--accentColor);
    cursor: pointer;
    text-decoration: none;
  }

  .nav-chevron::after {
    content: none;
  }

  .nav-chevron:hover {
    opacity: 0.8;
    transition: 100ms ease-out;
  }
</style>
